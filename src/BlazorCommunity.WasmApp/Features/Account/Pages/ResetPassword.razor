@page "/account/reset/{UserId}"
@inherits PageBase

<div class="el-center-500">

    <ElCard EnableAlwaysRender="true">
        <Header>
            <GoBack Title="设置新密�? Route="@PreviousRoute"></GoBack>
        </Header>
        <Body>
            <ElForm @ref="form" LabelPosition="@LabelAlign.Right" Inline="false" EnableAlwaysRender="true" Style="width: 400px; margin: 20px auto;text-align: center;">
                <ElFormItem TValue="string" Label="密码�? Prop="@nameof(PasswordModel.Password)" Required="true">
                    <ElInput TValue="string" Type="@InputType.Password" Placeholder="请输入新密码" Style="width:300px;"></ElInput>
                </ElFormItem>
                <ElFormItem TValue="string" Label="确认密码�? Prop="@nameof(PasswordModel.ConfirmPassword)" Required="true">
                    <ElInput TValue="string" Type="@InputType.Password" Placeholder="请再次输入新密码" Style="width:300px;"></ElInput>
                </ElFormItem>
                <ElFormActionItem Style="text-align:center;">
                    <ElButton Type="ButtonType.Default" OnClick="e=>ResetPwd()" Plain="true" Style="width:300px;margin-left: 100px;">确定</ElButton>
                </ElFormActionItem>
            </ElForm>
        </Body>
    </ElCard>
</div>