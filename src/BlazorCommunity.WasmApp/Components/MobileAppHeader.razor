@inherits PageBase
<div class="mobile-header">
    <div class="header-item mobile-logo" @onclick="@(e => NavigationManager.NavigateTo("/", true))">
        <img src="img/logo.svg" />
    </div>
    <div class="header-item mobile-search">
        <ElInput Type="@InputType.Text" TValue="string" Size="@InputSize.Small" Style="display:inline-block;" EnableAlwaysRender="true" EnableClearButton="true" Placeholder="Search" @bind-Value="SearchText"></ElInput>
        <ElButton Type="@ButtonType.Text" Size="@ButtonSize.Large" Icon="el-icon-search" OnClick="e => Search()"
                  Style="font-size:16px; color:white;margin:0px 10px 0px 10px !important">
        </ElButton>
    </div>
    <div class="header-item mobile-user">
        <AuthorizeView>
            <Authorized>
                <span style="min-width:50px;">@User?.NickName</span>
            </Authorized>
            <NotAuthorized>
                <span @onclick="e => Login()" style="margin-left:2px;margin-right:2px;min-width:50px;">Login</span>
            </NotAuthorized>
        </AuthorizeView>
        <ElDropdown EnableAlwaysRender="true">
            <Trigger>
                <span class="icon iconfont icon-navicon" style="color:white;margin-right:5px !important;"></span>
            </Trigger>
            <Items>
                @foreach (var menu in headerMenus)
                {
                    var target = menu.URL == "/" ? "_self" : "_blank";
                    <ElDropdownItem>
                        <a href="@menu.URL" target="@target" style="display: inline-block;width: 100%;">
                            <i class="@menu.Icon"></i>
                            @menu.Title
                        </a>
                    </ElDropdownItem>
                }
                <AuthorizeView>
                    <Authorized>
                        <ElDropdownItem OnClick="LoginOut">
                            <a>
                                <i class="icon iconfont icon-tuichu" style="font-size:16px !important"></i>
                                <span style="font-size:16px;color:#000000;text-decoration:none;">Logout</span>
                            </a>
                        </ElDropdownItem>
                    </Authorized>
                </AuthorizeView>
            </Items>
        </ElDropdown>
    </div>
</div>
