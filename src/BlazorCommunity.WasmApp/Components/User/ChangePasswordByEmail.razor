@inherits PageBase

<ElCard EnableAlwaysRender="true">

    <Body>
        @if (CheckverifyCodeSuccess)
        {
        <ElForm @ref="resetPasswordForm" LabelPosition="@LabelAlign.Right" Inline="false" EnableAlwaysRender="true" Style="width: 350px;">
            <ElFormItem TValue="string" Label="新密码：" Prop="@nameof(PasswordModel.Password)" Required="true">
                <ElInput TValue="string" PrefixIcon="el-icon-lock" SuffixIcon="el-icon-view" Type="@InputType.Password" Placeholder="请输入密�? Style="width:250px;"></ElInput>
            </ElFormItem>
            <ElFormItem TValue="string" Label="确认密码�? Prop="@nameof(PasswordModel.ConfirmPassword)" Required="true">
                <ElInput TValue="string" PrefixIcon="el-icon-lock" SuffixIcon="el-icon-view" Type="@InputType.Password" Placeholder="请输入确认密�? Style="width:250px;"></ElInput>
            </ElFormItem>
            <ElFormActionItem Style=" text-align: right; ">
                <ElButton Type="@ButtonType.Default" Plain="true" OnClick="e=>ReSetPassword()" Style="width:100%;padding-left:10px;padding-right:10px;">�? �</ElButton>
            </ElFormActionItem>
        </ElForm>
        }
        else
        {
            <ElForm @ref="form" LabelPosition="@LabelAlign.Right" Inline="false" EnableAlwaysRender="true">
                <ElFormItem TValue="string" Label="邮箱�? Prop="@nameof(PasswordModel.Email)" Required="true" EnableAlwaysRender="true">
                    <div class="content-flex-row">
                        <ElInput TValue="string" Type="@InputType.Text" Placeholder="请输入您绑定的邮�? Style="width:300px;" Disabled="btnInputDisabled" EnableAlwaysRender="true"></ElInput>
                        <ElButton Style="margin-left:20px;" Type="ButtonType.Default" Plain="true" OnClick="e => SendEmail()" Disabled="btnInputDisabled" EnableAlwaysRender="true">@BtnText</ElButton>
                    </div>
                </ElFormItem>
                <ElFormItem TValue="string" Label="验证码：" Prop="@nameof(PasswordModel.Code)" Required="false">
                    <div class="content-flex-row">
                        <ElInput TValue="string" Type="@InputType.Text" Placeholder="请输入验证码" Style="width:300px;"></ElInput>
                        <ElButton Style=" margin-left: 20px;" Type="ButtonType.Default" Plain="true" OnClick="e=>CheckAndNavigatToReset()">确定</ElButton>
                    </div>
                </ElFormItem>
            </ElForm>
        }
    </Body>
</ElCard>