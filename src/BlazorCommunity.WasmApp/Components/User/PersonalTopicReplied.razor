@inherits PersonalTopicTableBase<PersonalReplyDisplayDto>
<ElForm Inline="true" @ref="searchForm">
    <ElFormItem TValue="string" Label="标题" Prop="@nameof(SearchPersonalReplyCondition.Title)" Required="false">
        <ElInput Clearable="true" TValue="string" Placeholder="输入帖子标题" Style="width:300px;"></ElInput>
    </ElFormItem>
    <ElFormActionItem>
        <ElButton Type="@ButtonType.Default" Plain="true" OnClick="e=>SearchData()">搜索</ElButton>
    </ElFormActionItem>
</ElForm>
<div class="el-divider el-divider--horizontal" style="margin: 5px 0;"><!----></div>
<ElTable DataSource="Datas" AutoGenerateColumns="false" Total="DataCount" @bind-CurrentPage="CurrentPage" PageSize="pageSize" @ref="table" HasSelectionColumn="false" IsStripe="true">
    <ElTableColumns>
        <ElTableColumn Width="500" Property="@nameof(PersonalReplyDisplayDto.Title)" Text="标题">
            <span style="float:left;" @onclick="e=>LinktoTopic(context)">@(((PersonalReplyDisplayDto)context).Title)</span>
        </ElTableColumn>
        <ElTableColumn Width="100" Property="@nameof(PersonalReplyDisplayDto.Author)" Text="发帖人"></ElTableColumn>
        <ElTableColumn Width="100" Format="yyyy-MM-dd" Property="@nameof(PersonalReplyDisplayDto.CreateDate)" Text="回复时间"></ElTableColumn>
        <ElTableColumn Width="100" Property="@nameof(PersonalReplyDisplayDto.Content)" Text="回复内容">
            <ElButton Type="@ButtonType.Text" OnClick="e=>ShowContent(context)">查看</ElButton>
        </ElTableColumn>
        <ElTableTemplateColumn Text="操作" Width="100">
            <ElButton Type="@ButtonType.Danger" Size="@ButtonSize.Small" Style="border-color:transparent !important" Plain="true" Circle="true" Icon="el-icon-remove-outline" OnClick="@(e=> Del(context))">
            </ElButton>
            <ElButton Type="@ButtonType.Success" Size="@ButtonSize.Small" Style="border-color:transparent !important" Plain="true" Circle="true" Icon="el-icon-link" OnClick="@(e=> LinktoTopic(context))">
            </ElButton>
        </ElTableTemplateColumn>
    </ElTableColumns>
</ElTable>