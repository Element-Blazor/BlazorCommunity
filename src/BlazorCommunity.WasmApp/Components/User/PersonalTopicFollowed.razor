@inherits PersonalTopicTableBase<PersonalFollowDisplayDto>

<ElForm Inline="true" @ref="searchForm">
    <ElFormItem TValue="string" Label="标题" Prop="@nameof(SearchPersonalFollowCondition.TopicTitle)" Required="false">
        <ElInput Clearable="true" TValue="string" Placeholder="输入帖子标题" Style="width:300px;"></ElInput>
    </ElFormItem>
    <ElFormActionItem>
        <ElButton Type="@ButtonType.Default" Plain="true" OnClick="e=>SearchData()">搜索</ElButton>
    </ElFormActionItem>
</ElForm>
<div class="el-divider el-divider--horizontal" style="margin: 5px 0;"><!----></div>
<ElTable DataSource="Datas" AutoGenerateColumns="false" Total="DataCount" @bind-CurrentPage="CurrentPage" PageSize="pageSize" @ref="table" HasSelectionColumn="false" IsStripe="true">
    <ElTableColumns>
        <ElTableColumn Width="500" Property="@nameof(PersonalFollowDisplayDto.Title)" Text="标题">
            <span style="float:left;" @onclick="e=> LinktoTopic(context)">@(((PersonalFollowDisplayDto)context).Title)</span>
        </ElTableColumn>
        <ElTableColumn Width="100" Property="@nameof(PersonalFollowDisplayDto.NickName)" Text="发帖人"></ElTableColumn>
        <ElTableColumn Width="100" Format="yyyy-MM-dd" Property="@nameof(PersonalFollowDisplayDto.CreateDate)" Text="收藏时间"></ElTableColumn>
        <ElTableTemplateColumn Text="操作" Width="100">
            <ElButton Type="@ButtonType.Danger" Size="@ButtonSize.Mini" Style="border-color:transparent !important" Plain="true" Circle="true" Icon="el-icon-remove-outline" OnClick="@(e=> Del(context))"></ElButton>
            <ElButton Type="@ButtonType.Success" Size="@ButtonSize.Mini" Style="border-color:transparent !important" Plain="true" Circle="true" Icon="el-icon-link" OnClick="@(e=> LinktoTopic(context))"></ElButton>
        </ElTableTemplateColumn>
    </ElTableColumns>
</ElTable>