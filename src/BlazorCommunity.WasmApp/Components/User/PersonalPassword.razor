@layout PersonalCenterLayout
@page "/user/pwd"
@inherits PersonalPageBase

<ElTabs Type="@TabType.Card" EnableAlwaysRender="true">
    <ElTabPane Title="@tabTitle" EnableAlwaysRender="true">
        <ElTabs EnableAlwaysRender="true">
            <ElTabPane Title="密码验证">
                <ChangePasswordByOldPassword></ChangePasswordByOldPassword>
            </ElTabPane>
            <ElTabPane Title="邮箱验证">
                <ChangePasswordByEmail></ChangePasswordByEmail>
            </ElTabPane>
            <ElTabPane Title="手机验证" EnableAlwaysRender="true">
                <ChangePasswordByMobile></ChangePasswordByMobile>
            </ElTabPane>
        </ElTabs>
    </ElTabPane>
</ElTabs>