@inherits PageBase
<div class="reply-now">
    @*<ElCard EnableAlwaysRender="true">
        <Header>*@
            <div class="content-flex-row custome-button-hover">
                <div style="margin:25px 0px;font-weight:800;">发表回复</div>
                <div style="margin:15px;position: absolute;right: 1px; ">
                    <button type="button" style="color:#909399;font-size:16px;" class="el-button el-button--text"
                            @onclick="e=>FullScreen()">
                        <span style="font-size:12px;">全屏模式</span>
                        <i class="el-icon-full-screen"></i>
                    </button>
                </div>
            </div>
        @*</Header>
        <Body>*@
            <ElForm Inline="false" @ref="form" Model="Model" LabelPosition="left" EnableAlwaysRender="true">
                <ElFormItem TValue="string" Required="false"  Prop="@nameof(NewReplyModel.Content)" EnableAlwaysRender="true" @ref="formItem">
                    <ElMarkdownEditor @ref="bMarkdownEditor"  UploadUrl="@(UploadUrl+ UploadPath.Topic.Description())" DisableFileUpload="true" DisableImageUpload="false" Height="300" ImageMaxSize="ConstConfig.MaxUploadFileSize" EnableAlwaysRender="true"></ElMarkdownEditor>
                    <div>
                        <span class="el-tag el-tag--warning el-tag--light" style="width:100%">温馨提示：上传图片，单张图片最大只允许@(ConstConfig.MaxUploadFileSize)k</span>
                    </div>
                </ElFormItem>
                <ElFormItem TValue="object" Style="text-align:left">
                    <ElButton Type="@ButtonType.Success" OnClick="e=>SubmitData()" Plain="true">立即回复</ElButton>
                </ElFormItem>
            </ElForm>
        @*</Body>
    </ElCard>*@
</div>