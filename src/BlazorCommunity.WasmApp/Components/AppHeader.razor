@inherits PageBase
<div class="nav">
    <div class="container app-header-dropdown">
        <img src="img/logo.png" style="width:80px;height:64px;margin-top:0px !important;" @onclick="@(e=>NavigationManager.NavigateTo("/"))"/>
        <div class="fill"></div>
        @if (headerMenus.Any())
        {
            <ul role="menubar" class="el-menu--horizontal el-menu" style="overflow:auto;">

                @foreach (var menu in headerMenus)
                {
                    <li role="menuitem" tabindex="0" class="el-menu-item is-active" style="background-color:transparent;color:#fff; border-bottom-color:#fff;">
                        @{
                            var target = @menu.URL == "/" ? "_self" : "_blank";
                            <a href="@menu.URL" target=@target>
                                <i class="@menu.Icon"></i>
                                @menu.Title
                            </a>
                        }

                    </li>
                }
            </ul>

        }
    <div class="fill">
    </div>
        <div style="flex:1;">
            <AuthorizeView>
                <Authorized>
                    <ElDropdown EnableAlwaysRender="true">
                        <Trigger>
                            <ElButton Style="border:none;background:transparent;padding:0px;">
                                <div style="display:flex;">
                                    <img src="@User?.Avator" class="app-nav-avatar-img" />
                                    <span class="el-dropdown-link" style="margin:auto;color:#fff;">
                                        @User?.NickName  <i class="el-icon-arrow-down el-icon--right" style="color:#fff;"></i>
                                    </span>
                                </div>
                            </ElButton>
                        </Trigger>
                        <Items>
                            <ElDropdownItem OnClick="e=>Personal()">дёЄдєєдё­еїѓ</ElDropdownItem>
                            <ElDropdownItem OnClick="e=>LoginOut()">йЂЂе‡єз™»еЅ</ElDropdownItem>

                        </Items>
                    </ElDropdown>
                </Authorized>
                <NotAuthorized>
                    <div style="display:flex;">
                        <ElButton Type="@ButtonType.Primary" OnClick="e=>Login()" Style="padding:12px 5px;">з™»еЅ•</ElButton>
                        <ElButton Type="@ButtonType.Primary" OnClick="e=>Regist()" Style="padding:12px 5px;margin-left:0px !important">жіЁе†Њ</ElButton>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</div>
