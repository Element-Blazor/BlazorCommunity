
<div class="margin-top-5 content-east" style="@Style">
    <ElLayout NorthHeight="30" EnableAlwaysRender="true">
        <North>
            <div class="newtopic">
                <AppTop></AppTop>
            </div>
        </North>
        <Center>

            @if (IsTopicDetailPage)
            {
                <div class="content-card" style="margin-top:14px;">
                    <ElCard Shadow="@ShadowShowType.Never">
                        <Body>
                            <TopicUserInfo></TopicUserInfo>
                        </Body>
                    </ElCard>
                </div>

                <div class="content-card" style="margin-top:10px;">
                    <ElCard Shadow="@ShadowShowType.Never">
                        <Body>
                            <UserTopics></UserTopics>
                        </Body>
                    </ElCard>
                </div>
            }
            @*<div class="content-card" style="margin-top:14px;">
                    <ElCard Shadow="@ShadowShowType.Never" Style="height:100px;">
                        <Body>
                            <AskDaily></AskDaily>
                        </Body>
                    </ElCard>
                </div>*@
            <div class="content-card" style="margin-top:14px;">
                <ElCard Shadow="@ShadowShowType.Never">
                    <Body>
                        <AppRightTop></AppRightTop>
                    </Body>
                </ElCard>
            </div>
            <div class="content-card margin-top-10">
                <ElCard Shadow="@ShadowShowType.Never">
                    <Body>
                        <AppRightCenter></AppRightCenter>
                    </Body>
                </ElCard>
            </div>
            <div class="content-card margin-top-10">
                <ElCard Shadow="@ShadowShowType.Never">
                    <Body>
                        <AppRightBottom></AppRightBottom>
                    </Body>
                </ElCard>
            </div>
        </Center>
    </ElLayout>
</div>

@code{
    [Parameter]
    public string Style { get; set; } = "";

    protected bool IsTopicDetailPage = false;
    [Inject]
    NavigationManager NavigationManager { get; set; }
    protected override void OnInitialized()
    {
        IsTopicDetailPage = NavigationManager.Uri.ToLower().Contains("/topic/");
    }
}