@layout PersonalCenterLayout
@page "/user/avator"
@inherits PersonalAvatorBase
<ElTabs Type="@TabType.Card" EnableAlwaysRender="true">
    <ElTabPane Title="@tabTitle" EnableAlwaysRender="true">
        <ElForm Style="width:400px;" @ref="ElForm" Model="value" EnableAlwaysRender="true">

            <ElFormItem TValue="IFileModel[]" Label="" Prop="@nameof(UploadActivity.Previews)" EnableAlwaysRender="true">
                <UploadAvatar Url="@(UploadUrl+ UploadPath.Avator.Description())"
                              UploadType="UploadType.Image"
                              EnablePasteUpload="true" Limit="1" MaxSize="300"
                              AllowExtensions="@(new string[] { " .jpg",".png"})" EnableAlwaysRender="true">
                </UploadAvatar>
            </ElFormItem>
            <ElFormActionItem>
                <ElButton Type="@ButtonType.Primary" Style="width:178px;" OnClick="e=>Submit()" Plain="true">õ┐? Õ¡</ElButton>
            </ElFormActionItem>
        </ElForm>
    </ElTabPane>
</ElTabs>