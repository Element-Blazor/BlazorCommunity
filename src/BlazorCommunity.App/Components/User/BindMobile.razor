@inherits BindMobileBase

<ElCard EnableAlwaysRender="true" @ref="bCard">
    <Body>
        @if (value != null && !string.IsNullOrWhiteSpace(value.Mobile))
        {
            <ElForm @ref="ElForm" Model="value" LabelPosition="@LabelAlign.Right" Inline="true" EnableAlwaysRender="true">
                <ElFormItem TValue="string" Label="" Prop="@nameof(PasswordModel.Mobile)" Required="false">
                    <ElButton Type="ButtonType.Info" Plain="true" Style="border:none" Disabled="true">@($"宸茬粦瀹氾細{ value.Mobile}")</ElButton>
                </ElFormItem>
            </ElForm>
        }
        else
        {
            <ElForm @ref="ElForm" Model="value" LabelPosition="@LabelAlign.Right" Inline="true" EnableAlwaysRender="true">
                <ElFormItem TValue="string" Label="Mobile" Prop="@nameof(PasswordModel.Mobile)" Required="true">
                    <ElInput TValue="string" Type="@InputType.Tel" Placeholder="Mobile number"></ElInput>
                </ElFormItem>
                <ElFormActionItem EnableAlwaysRender="true" Style="text-align-last:right;">

                    <ElButton Type="@ButtonType.Default" Plain="true" OnClick="e => SendBindMobileMsg()" EnableAlwaysRender="true" Disabled="IsDisabled">
                        @((TimeOut > 0 && TimeOut < CountDownTime) ? $"Wait {TimeOut}s" : "Send code")
                    </ElButton>
                </ElFormActionItem>
                @if (showInput)
                {
                    <ElFormItem TValue="string" Label="楠岃瘉鐮侊細" Prop="@nameof(PasswordModel.Code)" Required="false">
                        <ElInput TValue="string" Placeholder="璇疯緭鍏ラ獙璇佺爜"></ElInput>
                    </ElFormItem>
                    <ElFormActionItem EnableAlwaysRender="true" Style="text-align-last:right;">
                        <ElButton Type="@ButtonType.Default" Plain="true" OnClick="e => CheckAndBindMobileVerifyCode()" EnableAlwaysRender="true">
                            缁戝畾
                        </ElButton>
                    </ElFormActionItem>
                }
            </ElForm>
        }
    </Body>
</ElCard>