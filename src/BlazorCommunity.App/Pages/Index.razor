@page "/"
@inherits IndexBase
<div class="container">
    <ElLayout EnableAlwaysRender="true" @ref="blayout">
        <Center>
            <ElTabs TabPosition="@TabPosition.Top" OnActiveTabChanged="ActiveTabChanged" EnableAlwaysRender="true" @ref="btab">
                @foreach (var item in Tabs)
                {
                    <MainContent Title="@item.Title" TopicType="@item.Category" EnableAlwaysRender="true"></MainContent>
                }
            </ElTabs>
        </Center>
        <East>
            <AppRightLayout></AppRightLayout>
        </East>
    </ElLayout>
</div>