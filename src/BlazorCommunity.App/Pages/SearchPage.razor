@inherits SearchPageBase
@page "/search/{Text}"

<div class="container">
    <ElLayout EastWidth="350" EnableAlwaysRender="true">
        <Center>
            <ElTabs TabPosition="@TabPosition.Top" EnableAlwaysRender="true" Style="margin-top:-4px;">
                <GoHome></GoHome>
                <ElTabPane Title="" Style="margin-top:-5px;">
                    <SeachTopicContainer Datas="Datas" Total="@Total" currentPage="currentPage" PageSize="PageSize" OnItemClick="OnItemClick" CurrentPageChanged="LoadDatas" EnableAlwaysRender="true" AskQuestion="e=>Ask()">
                    </SeachTopicContainer>
                </ElTabPane>
            </ElTabs>
        </Center>
        <East>
            <AppRightLayout Style="margin-top:9px !important;"></AppRightLayout>
        </East>
    </ElLayout>
</div>