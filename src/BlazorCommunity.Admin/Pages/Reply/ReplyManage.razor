@page "/manage/reply"
@using BlazorCommunity.Admin.QueryCondition
@using BlazorCommunity.DTO.Admin;
@inherits ReplyManageBase

<ElForm Inline="true" @ref="searchForm">
    <ElFormItem TValue="string" Label="дЄїиііж†ЗйҐШ" Prop="@nameof(QueryReplyCondition.Title)" Required="false">
        <ElInput Clearable="true" TValue="string"></ElInput>
    </ElFormItem>
    <ElFormItem TValue="string" Label="еЫЮеЄЦзФ®жИЈ" Prop="@nameof(QueryReplyCondition.UserName)" Required="false">
        <ElInput Clearable="true" TValue="string"></ElInput>
    </ElFormItem>
    <ElFormItem TValue="DelStatus?" Label="зКґжА? Prop="@nameof(QueryReplyCondition.Status)" Required="false">
        <div style="width:100px;"><ElSelect TValue="DelStatus?" Value="DelStatus.Normal"></ElSelect></div>
    </ElFormItem>
    <ElFormItem TValue="DateTime?" Label="еЫЮе§НжЧґйЧі" Required="false" Prop="@nameof(QueryReplyCondition.CreateDateStart)">
