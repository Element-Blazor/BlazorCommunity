@page "/manage/role"
@using BlazorCommunity.Admin.QueryCondition
@using BlazorCommunity.DTO.Admin;
@inherits RoleManageBase

<ElForm Inline="true">
    <ElButton Type="@ButtonType.Success" Icon="el-icon-plus" OnClick="New" Plain="true" Disabled="false" Style="float:right;margin-right:100px;">新增</ElButton>
</ElForm>

<div class="el-divider el-divider--horizontal" style="margin: 5px 0;"><!----></div>
<ElTable DataSource="Datas" Total="DataCount" @bind-CurrentPage="CurrentPage" PageSize="pageSize" @ref="table" HasSelectionColumn="false" IsStripe="true" AutoGenerateColumns="false">
    <ElTableColumns>
        <ElTableColumn Property="@nameof(RoleDisplayDto.Id)" Text="Id" Style="text-align:center;"></ElTableColumn>
        <ElTableColumn Property="@nameof(RoleDisplayDto.Name)" Text="名称" Style="text-align:center;"></ElTableColumn>

        <ElTableTemplateColumn Text="操作" Width="150">
            <ElButton Type="@ButtonType.Primary" Size="@ButtonSize.Small" Plain="true" OnClick="@(e=> Modify(context))">编辑</ElButton>
            <ElButton Type="@ButtonType.Success" Size="@ButtonSize.Small" Plain="true" OnClick="@(e=> ModifyClaims(context))">Claims</ElButton>
            <ElButton Type="@ButtonType.Danger" Size="@ButtonSize.Small" Plain="true" OnClick="@(e=> Delete(context))">删除</ElButton>
        </ElTableTemplateColumn>
    </ElTableColumns>
</ElTable>