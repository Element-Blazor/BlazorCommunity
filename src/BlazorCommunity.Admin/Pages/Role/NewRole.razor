@using BlazorCommunity.DTO.Admin
@inherits NewRoleBase

    <ElForm Style="width:100%;" @ref="roleForm" Model="model" LabelPosition="right">
        <ElFormItem TValue="string" Label="Id" Prop="@nameof(RoleDisplayDto.Id)" IsHidden="@(EntryOperation==BlazorCommunity.Admin.Enum. EntryOperation.Add)">
            <ElInput TValue="string" Disabled="true"></ElInput>
        </ElFormItem>

        <ElFormItem TValue="string" Label="角色名称" Prop="@nameof(RoleDisplayDto.Name)" Required="true">
            <ElInput Clearable="true" TValue="string"></ElInput>
        </ElFormItem>

        <ElFormItem TValue="object" Style="text-align:center;margin:0 auto;">
            <ElButton Type="@ButtonType.Primary" Plain="true" OnClick="e=>Save()" Style="text-align:center;width:100px;">保存</ElButton>
            <ElButton Type="@ButtonType.Default" Plain="true" OnClick="e=>roleForm.Reset()" Style="text-align:center;width:100px;">重置</ElButton>
        </ElFormItem>
    </ElForm>