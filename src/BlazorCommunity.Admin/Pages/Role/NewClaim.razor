@using BlazorCommunity.DTO.Admin
@inherits NewClaimBase

    <ElForm Style="width:100%;" @ref="claimForm" Model="model" LabelPosition="@LabelAlign.Right" EnableAlwaysRender="true">
        <ElFormItem TValue="string" Label="RoleId" Prop="@nameof(RoleClaimDto.RoleId)" EnableAlwaysRender="true">
            <ElInput TValue="string"  EnableAlwaysRender="true" Disabled="true"></ElInput>
        </ElFormItem>

        <ElFormItem TValue="string" Label="ClaimType" Prop="@nameof(RoleClaimDto.ClaimType)" Required="true" EnableAlwaysRender="true">
            <ElInput Clearable="true" TValue="string" EnableAlwaysRender="true"></ElInput>
        </ElFormItem>
        <ElFormItem TValue="string" Label="ClaimValue" Prop="@nameof(RoleClaimDto.ClaimValue)" Required="true" EnableAlwaysRender="true">
            <ElInput Clearable="true" TValue="string" EnableAlwaysRender="true"></ElInput>
        </ElFormItem>
        <ElFormItem TValue="object" Style="text-align:center;margin:0 auto;">
            <ElButton Type="@ButtonType.Primary" Plain="true" OnClick="e=>Save()" Style="text-align:center;width:100px;">保存</ElButton>
            <ElButton Type="@ButtonType.Default" Plain="true" OnClick="e=>claimForm.Reset()" Style="text-align:center;width:100px;">重置</ElButton>
        </ElFormItem>
    </ElForm>
