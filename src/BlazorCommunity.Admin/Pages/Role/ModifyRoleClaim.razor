@using BlazorCommunity.DTO.Admin
@inherits ModifyRoleClaimBase

<ElForm Inline="true">
    <ElButton Type="@ButtonType.Success" Icon="el-icon-plus" OnClick="New" Plain="true" Disabled="false">新增</ElButton>
</ElForm>
<ElTable DataSource="Claims" @ref="table" HasSelectionColumn="false" IsStripe="true" AutoGenerateColumns="false">
    <ElTableColumns>
        <ElTableColumn Property="@nameof(RoleClaimDto.ClaimType)" Text="类型" Style="text-align:center;"></ElTableColumn>
        <ElTableColumn Property="@nameof(RoleClaimDto.ClaimValue)" Text="描述" Style="text-align:center;"></ElTableColumn>

        <ElTableTemplateColumn Text="操作" Width="150">
            <ElButton Type="@ButtonType.Danger" Size="@ButtonSize.Small" Plain="true" OnClick="@(e=> Delete(context))">删除</ElButton>
        </ElTableTemplateColumn>
    </ElTableColumns>
</ElTable>
