@inherits AdminLoginBase
<div class="login-container">
    <ElForm @ref="Form">
        <div class="title-container">
            <h3 class="title">
                社区后台系统登录
            </h3>
        </div>
        <ElFormItem Required="true" TValue="string" Error="请输入账号" Prop="@nameof(LoginInfoModel.Username)">
            <ElInput PrefixIcon="el-icon-user-solid" TValue="string" Placeholder="账号"></ElInput>
        </ElFormItem>
        <ElFormItem Required="true" TValue="string" Error="请输入密码" Prop="@nameof(LoginInfoModel.Password)" EnableAlwaysRender="true">
            <ElInput PrefixIcon="el-icon-lock" SuffixIcon="el-icon-view" OnSuffixIconClick="TogglePassword" Type="@passwordType" TValue="string" Placeholder="密码"></ElInput>
        </ElFormItem>
        <ElFormActionItem>
            <ElButton Type="@ButtonType.Primary" OnClick="LoginAsync" Style="width:100%;">登录</ElButton>
        </ElFormActionItem>
    </ElForm>
</div>