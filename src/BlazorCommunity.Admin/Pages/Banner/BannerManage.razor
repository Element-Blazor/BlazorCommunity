@page "/manage/banner"
@using BlazorCommunity.DTO.Admin
@inherits BannerManageBase

<ElForm Inline="true">
    <ElButton Type="@ButtonType.Success" Icon="el-icon-plus" OnClick="New" Plain="true" Disabled="false" Style="float:right;margin-right:100px;">新增</ElButton>
</ElForm>

<div class="el-divider el-divider--horizontal" style="margin: 5px 0;"><!----></div>

<ElTable DataSource="Datas" Total="DataCount" @bind-CurrentPage="CurrentPage" PageSize="pageSize" @ref="table" HasSelectionColumn="false" IsStripe="true" AutoGenerateColumns="false">
    <ElTableColumns>
        <ElTableColumn Width="300" Property="@nameof(BannerDisplayDto.BannerImg)" Text="图片" Style="text-align:center;">
            @{
                BannerDisplayDto banner = ((BannerDisplayDto)context);
                <img src="@(banner.BannerImg)" style="width:100%;height:100px;" title="@banner.Title" />
            }
        </ElTableColumn>
        <ElTableColumn Width="300" Property="@nameof(BannerDisplayDto.Title)" Text="图片描述" Style="text-align:center;"> </ElTableColumn>
        <ElTableColumn Width="100" Property="@nameof(BannerDisplayDto.CreateDate)" Format="yyyy-MM-dd" Text="创建时间" Style="text-align:center;"></ElTableColumn>
        <ElTableColumn Width="100" Property="@nameof(BannerDisplayDto.Show)" Text="是否显示" Style="text-align:center;"></ElTableColumn>
        <ElTableTemplateColumn Text="操作" Width="150">

            <ElButton Type="@ButtonType.Primary" Size="@ButtonSize.Small" Plain="true" OnClick="@(e=> Modify(context))" Disabled="false">   编辑   </ElButton>
            @{

                var banner = (BannerDisplayDto)context;
                if (banner.Status == 0)
                {
                    <ElButton Type="@ButtonType.Danger" Size="@ButtonSize.Small" Plain="true" OnClick="@(e=> Delete(context))">删除</ElButton>
                }
                else
                {
                    <ElButton Type="@ButtonType.Success" Size="@ButtonSize.Small" Plain="true" OnClick="@(e=> Resume(context))">恢复</ElButton>
                }

            }
        </ElTableTemplateColumn>
    </ElTableColumns>
</ElTable>